# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
HF_TOKEN=hf_...

# === Brand Guidelines (pick ONE method) ===
# Option A — blob storage URL (recommended for deploy)
# BRAND_GUIDELINES_URL=https://your-blob.public.blob.vercel-storage.com/brand_guidelines.md
#
# Option B — local file path (for development)
# BRAND_GUIDELINES_FILE=./brand_guidelines.md
#
# Option C — inline (for short guidelines only)
# BRAND_GUIDELINES="Your brand guidelines here..."

# === Sitemaps (JSON object: name -> URL) ===
SITEMAPS={"triumph-uk": "https://uk.triumph.com/sitemap_index.xml", "triumph-de": "https://de.triumph.com/sitemap_index.xml"}

# === GSC Service Account (pick ONE method) ===
# Option A — inline JSON (recommended for deploy, no file needed)
# GSC_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", ...}
#
# Option B — local file path (for development)
# GSC_SERVICE_ACCOUNT_FILE=./service-account.json
